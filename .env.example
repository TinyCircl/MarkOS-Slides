PORT=3210
GRPC_PORT=50051
MARKOS_GRPC_HOST=127.0.0.1
MARKOS_PUBLIC_BASE_URL=
MARKOS_PREVIEW_SITE_BASE_URL=
MARKOS_BODY_LIMIT=20mb
MARKOS_SESSION_TTL_MS=900000
MARKOS_MAX_PREVIEW_SESSIONS=1000
MARKOS_LOCAL_ARTIFACT_RETENTION_MS=604800000
MARKOS_LOCAL_ARTIFACT_CLEANUP_INTERVAL_MS=3600000

# CORS: "true" allows all origins; comma-separated list restricts to specific origins
MARKOS_CORS_ORIGIN=true
# Rate limiting
MARKOS_RATE_LIMIT_WINDOW_MS=900000
MARKOS_RATE_LIMIT_MAX=100
# Request timeout (ms)
MARKOS_REQUEST_TIMEOUT_MS=60000

R2_PUBLIC_ACCOUNT_ID=
R2_PUBLIC_ACCESS_KEY=
R2_PUBLIC_SECRET_KEY=
R2_PUBLIC_BUCKET=paperpuppy
R2_PUBLIC_DOMAIN=https://assets.yanfd.com
R2_PRIVATE_PATH_PREFIX=preview
# Optional: dedicated prefix for exported artifacts. Defaults to {R2_PRIVATE_PATH_PREFIX}/exports
R2_RENDER_PATH_PREFIX=
