# Renderer frontmatter overrides.
# Supported values:
# - true / false / auto / dev / [] / {} / any raw YAML scalar/object string
# - default = keep the deck's original value
#
# Common high-impact switches:
# - DOWNLOAD: avoid implicit PDF generation during preview builds
# - SEO_META_OG_IMAGE: avoid post-build OG image generation
# - MONACO / TWOSLASH / REMOTE_ASSETS: useful when isolating heavy editor/highlighter/network paths
# - THEME / ADDONS: set to `default` to keep deck values, or force a specific theme / empty addon list
SLIDEV_OVERRIDE_FAULT_TOLERANCE=true
SLIDEV_OVERRIDE_DOWNLOAD=false
SLIDEV_OVERRIDE_SEO_META_OG_IMAGE=false
SLIDEV_OVERRIDE_MONACO=false
SLIDEV_OVERRIDE_PRESENTER=false
SLIDEV_OVERRIDE_DRAWINGS={enabled: false}
SLIDEV_OVERRIDE_WAKE_LOCK=false
SLIDEV_OVERRIDE_RECORD=false
SLIDEV_OVERRIDE_BROWSER_EXPORTER=false
SLIDEV_OVERRIDE_CODE_COPY=false
SLIDEV_OVERRIDE_CONTEXT_MENU=false
SLIDEV_OVERRIDE_PRELOAD_IMAGES=false
SLIDEV_OVERRIDE_REMOTE_ASSETS=false
SLIDEV_OVERRIDE_TWOSLASH=default
SLIDEV_OVERRIDE_ADDONS=default
SLIDEV_OVERRIDE_THEME=default
SLIDEV_OVERRIDE_INFO=default
SLIDEV_OVERRIDE_MDC=default
