{
  "name": "@tinycircl/markos-slides-core",
  "version": "0.2.0",
  "description": "Core build engine for turning Markdown slide sources into static web slide sites.",
  "license": "MIT",
  "type": "module",
  "files": [
    "assets/",
    "README.md",
    "index.mjs",
    "src/",
    "themes/"
  ],
  "keywords": [
    "markdown",
    "slides",
    "presentation",
    "static-site",
    "markos"
  ],
  "exports": {
    ".": "./index.mjs",
    "./artifact-store": "./src/core/artifact-store.mjs",
    "./config": "./src/config/index.mjs",
    "./deck-utils": "./src/core/deck-utils.mjs",
    "./dev-server": "./src/core/dev-server.mjs",
    "./engines": "./src/engines/index.mjs",
    "./engines/markos-web": "./src/engines/markos-web/index.mjs",
    "./manifest-site": "./src/core/manifest-site.mjs",
    "./path-utils": "./src/core/path-utils.mjs"
  },
  "dependencies": {
    "marked": "^16.4.2",
    "playwright-core": "^1.59.1",
    "pptxgenjs": "^4.0.1",
    "yaml": "^2.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
