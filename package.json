{
  "name": "@tinycircl/markos-slides",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "exports": {
    ".": "./src/index.mjs",
    "./core": "./src/core/index.mjs",
    "./cli": "./src/cli/index.mjs"
  },
  "bin": {
    "markos": "./src/cli.mjs"
  },
  "scripts": {
    "markos:build": "node src/cli.mjs build",
    "markos:dev": "node src/cli.mjs dev",
    "markos:theme": "node src/cli.mjs theme",
    "check": "npm test && npm run check:fixtures && npm run check:examples",
    "check:examples": "node scripts/check-examples.mjs",
    "check:fixtures": "node scripts/check-fixtures.mjs",
    "test": "node --test",
    "lint": "eslint packages/ src/ scripts/ test/",
    "lint:fix": "eslint packages/ src/ scripts/ test/ --fix",
    "format": "prettier --check packages/ src/ scripts/ test/",
    "format:fix": "prettier --write packages/ src/ scripts/ test/"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1"
  }
}
